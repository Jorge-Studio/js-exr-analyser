{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/upload.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/upload", "destination": "/api/upload" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
